rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ملفات كل couple معزولة في مجلدها، ولا يصلها غير عضويه.
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.coupleId == coupleId
        // قصْر الرفع على PDF/صور وبحد أقصى 15MB (مورد، لا ألبوم وسائط).
        && (request.resource == null
            || (request.resource.size < 15 * 1024 * 1024
                && request.resource.contentType.matches('application/pdf|image/.*')));
    }
  }
}
